  "security_concepts": {
    "role_based_access": {
      "description": "Each user has a role (FARMER/PROCESSOR/ROASTER/PACKAGER/RETAILER) embedded in X.509 certificate",
      "members": [1, 2, 3, 4, 5],
      "implementation": "Role extracted from JWT token (read from certificate attribute)"
    },
    "and_endorsement": {
      "description": "State-Based Endorsement: Requires endorsement from both Org1 AND Org2 for transfer acceptance",
      "setupMember": 3,
      "enforceMember": 4,
      "implementation": "Member 3: setStateValidationParameter(batchId, 'AND(...)')",
      "enforcement": "Member 4: acceptTransfer() cannot proceed without 2 org endorsements"
    },
    "evidence_verification": {
      "description": "SHA-256 hash stored on-chain, file stored on IPFS",
      "uploadMember": 3,
      "verifyMember": 5,
      "clientSideVerification": "Web Crypto API (crypto.subtle.digest)"
    },
    "chain_traversal": {
      "description": "Build full trace by following parentBatchId backwards",
      "member": 5,
      "direction": "Reverse: Packaged ← Roast ← Process ← Harvest"
    },
    "public_trace": {
      "description": "No authentication required for public trace endpoint",
      "member": 5,
      "endpoint": "GET /api/trace/{publicCode}",
      "auth": "NONE"
    }
  },
  "business_flow": {
    "step_1": {
      "actor": "Farmer (Member 1)",
      "action": "Create harvest batch + record farm activities",
      "output": "HARVEST_BATCH (status: COMPLETED)"
    },
    "step_2": {
      "actor": "Processor (Member 2)",
      "action": "Process parent harvest batch",
      "input": "HARVEST_BATCH (COMPLETED)",
      "output": "PROCESSED_BATCH (status: COMPLETED)"
    },
    "step_3": {
      "actor": "Roaster (Member 3)",
      "action": "Roast + upload evidence + request transfer",
      "input": "PROCESSED_BATCH (COMPLETED)",
      "output": "ROAST_BATCH (status: COMPLETED, TRANSFER_PENDING with AND policy)"
    },
    "step_4": {
      "actor": "Packager (Member 4)",
      "action": "Accept transfer + create packaged batch + generate QR",
      "input": "ROAST_BATCH (TRANSFER_PENDING)",
      "output": "PACKAGED_BATCH (status: COMPLETED), QR Code"
    },
    "step_5": {
      "actor": "Retailer (Member 5)",
      "action": "Manage inventory + provide public trace",
      "input": "PACKAGED_BATCH",
      "output": "Status: IN_STOCK → SOLD, Public trace with full chain"
    }
  },
