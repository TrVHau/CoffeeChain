# Backend production environment template

SPRING_DATASOURCE_URL=jdbc:postgresql://<postgres-host>:5432/coffeetrace?sslmode=require
SPRING_DATASOURCE_USERNAME=<postgres-user>
DB_PASSWORD=<postgres-password>

IPFS_API_URL=http://<ipfs-host>:5001
TRACE_PUBLIC_BASE_URL=https://app.your-domain.com/trace/

JWT_SECRET=<replace-with-strong-32-plus-char-secret>
CORS_ALLOWED_ORIGINS=https://app.your-domain.com

FABRIC_CHANNEL_NAME=coffee-traceability-channel
FABRIC_CHAINCODE_NAME=CoffeeTraceChaincode

FABRIC_ORG1_MSP_ID=Org1MSP
FABRIC_ORG2_MSP_ID=Org2MSP

FABRIC_ORG1_PEER_ENDPOINT=52.175.120.161:7051
FABRIC_ORG2_PEER_ENDPOINT=52.175.120.161:9051
FABRIC_ORG1_PEER_HOST_OVERRIDE=peer0.org1.example.com
FABRIC_ORG2_PEER_HOST_OVERRIDE=peer0.org2.example.com

FABRIC_ORG1_TLS_CERT_PATH=/crypto/peerOrganizations/org1.example.com/tlsca/tlsca.org1.example.com-cert.pem
FABRIC_ORG2_TLS_CERT_PATH=/crypto/peerOrganizations/org2.example.com/tlsca/tlsca.org2.example.com-cert.pem

FABRIC_ORG1_ADMIN_CERT_PATH=/crypto/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/signcerts/Admin@org1.example.com-cert.pem
FABRIC_ORG1_ADMIN_KEY_PATH=/crypto/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/keystore/

FABRIC_ORG2_ADMIN_CERT_PATH=/crypto/peerOrganizations/org2.example.com/users/Admin@org2.example.com/msp/signcerts/Admin@org2.example.com-cert.pem
FABRIC_ORG2_ADMIN_KEY_PATH=/crypto/peerOrganizations/org2.example.com/users/Admin@org2.example.com/msp/keystore/

FABRIC_ORG1_USERS_BASE_PATH=/crypto/peerOrganizations/org1.example.com/users
FABRIC_ORG2_USERS_BASE_PATH=/crypto/peerOrganizations/org2.example.com/users

# Render/remote bootstrap options for providing Fabric crypto material
FABRIC_CRYPTO_ARCHIVE_PATH=
FABRIC_CRYPTO_ARCHIVE_BASE64_PATH=
FABRIC_CRYPTO_ARCHIVE_B64=
